{
  "version": 2,
  "builds": [
    { "src": "api/**/*.js", "use": "@vercel/node" },
    { "src": "frontend/package.json", "use": "@vercel/static-build", "config": { "distDir": "dist" } }
  ],
  "routes": [
    { "src": "/api/todos/(.*)", "dest": "/api/todos.js" },
    { "src": "/api/todos", "dest": "/api/todos.js" },
    { "src": "/(.*)", "dest": "/frontend/$1" }
  ]
}